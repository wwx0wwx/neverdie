PANEL_PORT=41730
PANEL_API_PORT=41731
VITE_POLL_INTERVAL_MS=5000
VITE_STALE_AFTER_MS=15000
# Comma-separated list of peer panel API URLs for P2P config sync
PANEL_PEERS=http://panel-b.example.com:41731,http://panel-c.example.com:41731
# CORS origin for production (leave blank to allow any)
PANEL_ORIGIN=
LOG_LEVEL=info
# SQLite database file path (default: apps/panel/data/neverdie.db)
# DB_PATH=/var/data/neverdie.db
# Auth secrets (required in production)
JWT_SECRET=change-me-to-a-32-char-random-hex
PANEL_SECRET=change-me-to-a-32-char-random-hex
# Public domain of this panel (used to generate install commands)
PANEL_DOMAIN=panel.example.com
